AUDITFLOW_ENVIRONMENT=development
AUDITFLOW_STORAGE_ROOT=C:/Proyectos/AuditFlowAI/backend/storage
AUDITFLOW_MAX_UPLOAD_BYTES=5368709120
AUDITFLOW_UPLOAD_CHUNK_BYTES=8388608
AUDITFLOW_HEADER_SCAN_ROWS=50
AUDITFLOW_PROFILE_SAMPLE_VALUES=5
AUDITFLOW_DUCKDB_MEMORY_LIMIT=1GB
AUDITFLOW_DUCKDB_THREADS=4
AUDITFLOW_XLSX_MAX_UNCOMPRESSED_BYTES=21474836480
AUDITFLOW_XLSX_MAX_COMPRESSION_RATIO=1000
AUDITFLOW_SQLITE_BUSY_TIMEOUT_SECONDS=30
AUDITFLOW_JOB_WORKER_ENABLED=true
AUDITFLOW_JOB_POLL_INTERVAL_SECONDS=0.5
AUDITFLOW_JOB_LEASE_SECONDS=300
AUDITFLOW_JOB_HEARTBEAT_SECONDS=30
AUDITFLOW_JOB_SHUTDOWN_TIMEOUT_SECONDS=30
AUDITFLOW_JOB_DEFAULT_MAX_ATTEMPTS=3
AUDITFLOW_JOB_MAX_ATTEMPTS=10
AUDITFLOW_JOB_RETRY_BASE_SECONDS=5
AUDITFLOW_JOB_RETRY_MAX_SECONDS=3600
AUDITFLOW_JOB_RECOVERY_INTERVAL_SECONDS=60
